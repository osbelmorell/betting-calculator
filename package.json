{
  "name": "betting-calculator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbo",
    "build": "npm run calc:contract:sync && next build && npm run check:sitemap-host",
    "check:sitemap-host": "node scripts/check-sitemap-host.mjs",
    "a11y:smoke": "node scripts/a11y-route-smoke.mjs",
    "quality:gate": "node scripts/quality-gate.mjs",
    "business:review": "npm run quality:gate",
    "ci:verify": "npm run lint && npm run quality:gate && npm run calc:contract:check && next build && npm run a11y:smoke && npm run check:sitemap-host",
    "calc:contract:sync": "node scripts/sync-calculator-content-contract.mjs",
    "calc:contract:check": "node scripts/sync-calculator-content-contract.mjs --check",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "browserslist": [
    "chrome >= 93",
    "edge >= 93",
    "firefox >= 92",
    "safari >= 15.4",
    "ios_saf >= 15.4",
    "not dead"
  ],
  "devDependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.1",
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
